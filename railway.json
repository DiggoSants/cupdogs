{
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "php artisan serve --host=0.0.0.0 --port=${PORT}",
    "releaseCommand": "php artisan migrate --force && php artisan storage:link || true"
  },
  "env": {
    "APP_ENV": "production",
    "APP_DEBUG": "false",
    "APP_KEY": "${APP_KEY}",
    "APP_URL": "${APP_URL}",
    "DB_CONNECTION": "pgsql",
    "DATABASE_URL": "${DATABASE_URL}",
    "MAIL_MAILER": "smtp",
    "MAIL_HOST": "${MAIL_HOST}",
    "MAIL_PORT": "${MAIL_PORT}",
    "MAIL_USERNAME": "${MAIL_USERNAME}",
    "MAIL_PASSWORD": "${MAIL_PASSWORD}",
    "MAIL_ENCRYPTION": "tls"
  }
}
